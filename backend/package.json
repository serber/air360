{
  "name": "air360-api-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify-based API backend scaffold for Air360.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "kysely": "^0.28.16",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
